    {
      "title": "2. Modelo 03 - Word2Vec + MLP",
      "text": "%pyspark\nprint(json.dumps(metricas_w2v, indent\u003d2) if metricas_w2v else \u0027Metricas no disponibles\u0027)\n\nif metricas_w2v:\n    test_base \u003d spark.read.parquet(f\"{HDFS}/data/processed/test/\").select(\u0027text\u0027, \u0027label\u0027)\n    from pyspark.ml import PipelineModel\n    modelo_w2v \u003d PipelineModel.load(f\"{HDFS}/models/word2vec_mlp/\")\n    preds_w2v \u003d modelo_w2v.transform(test_base).select(\u0027label\u0027, \u0027prediction\u0027)\n    cm, reporte \u003d cm_desde_preds(preds_w2v)\n    pintar_cm(cm, \u0027Nivel 1 - Word2Vec + MLP\u0027)\n    print(reporte)",

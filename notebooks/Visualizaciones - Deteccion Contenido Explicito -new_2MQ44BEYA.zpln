            "type": "TEXT",
            "data": "{\n  \"model\": \"Word2Vec_GlobalAvgPool_MLP_SparkMLlib\",\n  \"auc_roc\": 0.8932,\n  \"f1_weighted\": 0.8465,\n  \"f1_macro\": 0.8061,\n  \"f1_explicit\": 0.7144,\n  \"f1_not_explicit\": 0.8977,\n  \"accuracy\": 0.8494,\n  \"precision_weighted\": 0.8456,\n  \"recall_weighted\": 0.8494,\n  \"train_time_s\": 413.1,\n  \"eval_time_s\": 6.8,\n  \"total_time_s\": 435.3\n}\n\u001b[0;31m---------------------------------------------------------------------------\u001b[0m\n\u001b[0;31mPy4JJavaError\u001b[0m                             Traceback (most recent call last)\nCell \u001b[0;32mIn[20], line 6\u001b[0m\n\u001b[1;32m      4\u001b[0m test_base \u001b[38;5;241m\u003d\u001b[39m spark\u001b[38;5;241m.\u001b[39mread\u001b[38;5;241m.\u001b[39mparquet(\u001b[38;5;124mf\u001b[39m\u001b[38;5;124m\"\u001b[39m\u001b[38;5;132;01m{\u001b[39;00mHDFS\u001b[38;5;132;01m}\u001b[39;00m\u001b[38;5;124m/data/processed/test/\u001b[39m\u001b[38;5;124m\"\u001b[39m)\u001b[38;5;241m.\u001b[39mselect(\u001b[38;5;124m\u0027\u001b[39m\u001b[38;5;124mtext\u001b[39m\u001b[38;5;124m\u0027\u001b[39m, \u001b[38;5;124m\u0027\u001b[39m\u001b[38;5;124mlabel\u001b[39m\u001b[38;5;124m\u0027\u001b[39m)\n\u001b[1;32m      5\u001b[0m \u001b[38;5;28;01mfrom\u001b[39;00m\u001b[38;5;250m \u001b[39m\u001b[38;5;21;01mpyspark\u001b[39;00m\u001b[38;5;21;01m.\u001b[39;00m\u001b[38;5;21;01mml\u001b[39;00m\u001b[38;5;250m \u001b[39m\u001b[38;5;28;01mimport\u001b[39;00m PipelineModel\n\u001b[0;32m----\u003e 6\u001b[0m modelo_w2v \u001b[38;5;241m\u003d\u001b[39m \u001b[43mPipelineModel\u001b[49m\u001b[38;5;241;43m.\u001b[39;49m\u001b[43mload\u001b[49m\u001b[43m(\u001b[49m\u001b[38;5;124;43mf\u001b[39;49m\u001b[38;5;124;43m\"\u001b[39;49m\u001b[38;5;132;43;01m{\u001b[39;49;00m\u001b[43mHDFS\u001b[49m\u001b[38;5;132;43;01m}\u001b[39;49;00m\u001b[38;5;124;43m/models/word2vec_mlp/\u001b[39;49m\u001b[38;5;124;43m\"\u001b[39;49m\u001b[43m)\u001b[49m\n\u001b[1;32m      7\u001b[0m preds_w2v \u001b[38;5;241m\u003d\u001b[39m modelo_w2v\u001b[38;5;241m.\u001b[39mtransform(test_base)\u001b[38;5;241m.\u001b[39mselect(\u001b[38;5;124m\u0027\u001b[39m\u001b[38;5;124mlabel\u001b[39m\u001b[38;5;124m\u0027\u001b[39m, \u001b[38;5;124m\u0027\u001b[39m\u001b[38;5;124mprediction\u001b[39m\u001b[38;5;124m\u0027\u001b[39m)\n\u001b[1;32m      8\u001b[0m cm, reporte \u001b[38;5;241m\u003d\u001b[39m cm_desde_preds(preds_w2v)\n\nFile \u001b[0;32m/opt/spark/python/lib/pyspark.zip/pyspark/ml/util.py:369\u001b[0m, in \u001b[0;36mMLReadable.load\u001b[0;34m(cls, path)\u001b[0m\n\u001b[1;32m    366\u001b[0m \u001b[38;5;129m@classmethod\u001b[39m\n\u001b[1;32m    367\u001b[0m \u001b[38;5;28;01mdef\u001b[39;00m\u001b[38;5;250m \u001b[39m\u001b[38;5;21mload\u001b[39m(\u001b[38;5;28mcls\u001b[39m, path: \u001b[38;5;28mstr\u001b[39m) \u001b[38;5;241m-\u001b[39m\u001b[38;5;241m\u003e\u001b[39m RL:\n\u001b[1;32m    368\u001b[0m \u001b[38;5;250m    \u001b[39m\u001b[38;5;124;03m\"\"\"Reads an ML instance from the input path, a shortcut of `read().load(path)`.\"\"\"\u001b[39;00m\n\u001b[0;32m--\u003e 369\u001b[0m     \u001b[38;5;28;01mreturn\u001b[39;00m \u001b[38;5;28;43mcls\u001b[39;49m\u001b[38;5;241;43m.\u001b[39;49m\u001b[43mread\u001b[49m\u001b[43m(\u001b[49m\u001b[43m)\u001b[49m\u001b[38;5;241;43m.\u001b[39;49m\u001b[43mload\u001b[49m\u001b[43m(\u001b[49m\u001b[43mpath\u001b[49m\u001b[43m)\u001b[49m\n\nFile \u001b[0;32m/opt/spark/python/lib/pyspark.zip/pyspark/ml/pipeline.py:282\u001b[0m, in \u001b[0;36mPipelineModelReader.load\u001b[0;34m(self, path)\u001b[0m\n\u001b[1;32m    281\u001b[0m \u001b[38;5;28;01mdef\u001b[39;00m\u001b[38;5;250m \u001b[39m\u001b[38;5;21mload\u001b[39m(\u001b[38;5;28mself\u001b[39m, path: \u001b[38;5;28mstr\u001b[39m) \u001b[38;5;241m-\u001b[39m\u001b[38;5;241m\u003e\u001b[39m \u001b[38;5;124m\"\u001b[39m\u001b[38;5;124mPipelineModel\u001b[39m\u001b[38;5;124m\"\u001b[39m:\n\u001b[0;32m--\u003e 282\u001b[0m     metadata \u001b[38;5;241m\u003d\u001b[39m \u001b[43mDefault
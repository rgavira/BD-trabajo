    {
      "title": "3. Modelo 07 - USE + MLlib MLP",
      "text": "%pyspark\nprint(json.dumps(metricas_use_mllib, indent\u003d2) if metricas_use_mllib else \u0027Metricas no disponibles\u0027)\n\nif metricas_use_mllib and HAS_SPARKNLP:\n    test_base \u003d spark.read.parquet(f\"{HDFS}/data/processed/test/\").select(\u0027text\u0027, \u0027label\u0027)\n    document \u003d DocumentAssembler().setInputCol(\u0027text\u0027).setOutputCol(\u0027document\u0027)\n    use \u003d UniversalSentenceEncoder.pretrained(\u0027tfhub_use\u0027, \u0027en\u0027).setInputCols([\u0027document\u0027]).setOutputCol(\u0027sentence_embeddings\u0027)\n    emb_model \u003d Pipeline(stages\u003d[document, use]).fit(test_base.limit(1))\n    test_feat \u003d (emb_model.transform(test_base)\n                 .withColumn(\u0027features\u0027, array_to_vector(F.col(\u0027sentence_embeddings\u0027).getItem(0)[\u0027embeddings\u0027]))\n                 .select(\u0027features\u0027, \u0027label\u0027))\n    mlp_model \u003d MultilayerPerceptronClassificationModel.load(f\"{HDFS}/models/spark_nlp_use_mllib_mlp/\")\n    preds_use_mllib \u003d mlp_model.transform(test_feat).select(\u0027label\u0027, \u0027prediction\u0027)\n    cm, reporte \u003d cm_desde_preds(preds_use_mllib)\n    pintar_cm(cm, \u0027Nivel 2 - USE + MLlib MLP\u0027)\n    print(reporte)\nelif metricas_use_mllib:\n    print(\u0027Metricas cargadas, pero Zeppelin no tiene Spark NLP para reconstruir la matriz de confusion\u0027)",

{
  "paragraphs": [
    {
      "title": "1. Carga y utilidades",
      "text": "%pyspark\nimport json\nimport matplotlib\nmatplotlib.use(\u0027Agg\u0027)\nimport matplotlib.pyplot as plt\nimport numpy as np\n#from sklearn.metrics import confusion_matrix, classification_report\n\nHDFS \u003d \"hdfs://namenode:9000\"\n\n\ndef listar_ficheros(path_dir):\n    jvm \u003d sc._jvm\n    conf \u003d sc._jsc.hadoopConfiguration()\n    fs \u003d jvm.org.apache.hadoop.fs.FileSystem.get(conf)\n    path \u003d jvm.org.apache.hadoop.fs.Path(path_dir)\n    if not fs.exists(path):\n        return []\n    rutas \u003d []\n    for estado in fs.listStatus(path):\n        nombre \u003d estado.getPath().getName()\n        if estado.isFile() and nombre.startswith(\u0027part-\u0027):\n            rutas.append(estado.getPath().toString())\n    return sorted(rutas)\n\n\ndef leer_json_desde_directorio(path_dir):\n    try:\n        rutas \u003d listar_ficheros(path_dir)\n        if not rutas:\n            print(f\"No hay ficheros JSON en {path_dir}\")\n            return None\n        texto \u003d \"\\n\".join(\n            row[\u0027value\u0027]\n            for row in spark.read.text(rutas).collect()\n            if row[\u0027value\u0027] and row[\u0027value\u0027].strip()\n        ).strip()\n        if not texto:\n            print(f\"No hay contenido JSON legible en {path_dir}\")\n            return None\n        return json.loads(texto)\n    except Exception as exc:\n        print(f\"No se pudieron leer metricas desde {path_dir}: {exc}\")\n        return None\n\n\ndef cm_desde_preds(preds_df):\n    pdf \u003d preds_df.select(\u0027label\u0027, \u0027prediction\u0027).toPandas()\n    cm \u003d confusion_matrix(pdf[\u0027label\u0027], pdf[\u0027prediction\u0027])\n    reporte \u003d classification_report(pdf[\u0027label\u0027], pdf[\u0027prediction\u0027], target_names\u003d[\u0027Clean\u0027, \u0027Explicit\u0027])\n    return cm, reporte\n\n\ndef pintar_cm(cm, titulo):\n    fig, ax \u003d plt.subplots(figsize\u003d(5, 4))\n    ax.imshow(cm, interpolation\u003d\u0027nearest\u0027, cmap\u003d\u0027Blues\u0027)\n    ax.set_title(titulo)\n    ax.set_xticks(np.arange(2))\n    ax.set_xticklabels([\u0027Clean\u0027, \u0027Explicit\u0027])\n    ax.set_yticks(np.arange(2))\n    ax.set_yticklabels([\u0027Clean\u0027, \u0027Explicit\u0027])\n    ax.set_xlabel(\u0027Predicho\u0027)\n    ax.set_ylabel(\u0027Real\u0027)\n    for i in range(cm.shape[0]):\n        for j in range(cm.shape[1]):\n            ax.text(j, i, str(cm[i, j]), ha\u003d\u0027center\u0027, va\u003d\u0027center\u0027, color\u003d\u0027white\u0027 if cm[i, j] \u003e cm.max() / 2 else \u0027black\u0027, fontweight\u003d\u0027bold\u0027)\n    plt.tight_layout()\n    plt.show()\n\n\nmetricas_w2v \u003d leer_json_desde_directorio(f\"{HDFS}/metrics/word2vec_mlp/\")\nmetricas_use_mllib \u003d leer_json_desde_directorio(f\"{HDFS}/metrics/spark_nlp_use_mllib_mlp/\")\nmetricas_sparknlp \u003d leer_json_desde_directorio(f\"{HDFS}/metrics/spark_nlp_classifierdl/\")\nmetricas_tf \u003d leer_json_desde_directorio(f\"{HDFS}/metrics/tensorflow_text_baselines/\")\n\nresultados_tf \u003d metricas_tf.get(\u0027results\u0027, []) if metricas_tf else []\nmejor_tf \u003d max(resultados_tf, key\u003dlambda x: x.get(\u0027f1_weighted\u0027, 0.0)) if resultados_tf else None\n\ntry:\n    import sparknlp\n    from sparknlp.base import DocumentAssembler\n    from sparknlp.annotator import UniversalSentenceEncoder\n    from pyspark.ml import Pipeline, PipelineModel\n    from pyspark.ml.classification import MultilayerPerceptronClassificationModel\n    from pyspark.ml.functions import array_to_vector\n    from pyspark.sql import functions as F\n    HAS_SPARKNLP \u003d True\nexcept Exception as exc:\n    HAS_SPARKNLP \u003d False\n    SPARKNLP_IMPORT_ERROR \u003d str(exc)\n\nprint(\u0027Word2Vec + MLP:\u0027, metricas_w2v is not None)\nprint(\u0027USE + MLlib MLP:\u0027, metricas_use_mllib is not None)\nprint(\u0027Spark NLP ClassifierDL:\u0027, metricas_sparknlp is not None)\nprint(\u0027TensorFlow:\u0027, metricas_tf is not None)\nprint(\u0027Spark NLP en Zeppelin:\u0027, HAS_SPARKNLP)",
      "user": "anonymous",

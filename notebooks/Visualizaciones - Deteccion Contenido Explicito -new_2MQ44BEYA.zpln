    {
      "title": "6. Comparativa final",
      "text": "%pyspark\nmodelos \u003d []\naccuracy \u003d []\nf1_weighted \u003d []\nf1_macro \u003d []\nauc \u003d []\n\nfor nombre, fuente in [\n    (\u0027Nivel 1\u0027, metricas_w2v),\n    (\u0027Nivel 2\u0027, metricas_use_mllib),\n    (\u0027Nivel 3\u0027, metricas_sparknlp),\n    (\u0027Nivel 4\u0027, mejor_tf),\n]:\n    if fuente:\n        modelos.append(nombre)\n        accuracy.append(fuente.get(\u0027accuracy\u0027) or 0.0)\n        f1_weighted.append(fuente.get(\u0027f1_weighted\u0027) or 0.0)\n        f1_macro.append(fuente.get(\u0027f1_macro\u0027) or 0.0)\n        auc.append(fuente.get(\u0027auc_roc\u0027) or 0.0)\n\nif not modelos:\n    print(\u0027No hay metricas disponibles para comparar\u0027)\nelse:\n    fig, axes \u003d plt.subplots(1, 4, figsize\u003d(22, 5))\n    series \u003d [(\u0027accuracy\u0027, accuracy), (\u0027f1_weighted\u0027, f1_weighted), (\u0027f1_macro\u0027, f1_macro), (\u0027auc_roc\u0027, auc)]\n    for ax, (titulo, valores) in zip(axes, series):\n        bars \u003d ax.bar(modelos, valores, color\u003d[\u0027#1f77b4\u0027, \u0027#2ca02c\u0027, \u0027#e4572e\u0027, \u0027#9467bd\u0027][:len(modelos)])\n        ax.set_title(titulo)\n        ax.set_ylim(0, 1.05)\n        ax.grid(axis\u003d\u0027y\u0027, alpha\u003d0.25)\n        for bar, valor in zip(bars, valores):\n            ax.text(bar.get_x() + bar.get_width()/2, bar.get_height() + 0.015, f\u0027{valor:.3f}\u0027, ha\u003d\u0027center\u0027, va\u003d\u0027bottom\u0027, fontsize\u003d9)\n    plt.tight_layout()\n    plt.show()",
